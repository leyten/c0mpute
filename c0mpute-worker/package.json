{
  "name": "@c0mpute/worker",
  "version": "1.1.0",
  "description": "Native CLI worker for the c0mpute.ai distributed inference network. Runs LLM inference using node-llama-cpp and connects to the orchestrator via Socket.io.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "c0mpute-worker": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "llm",
    "inference",
    "distributed",
    "gpu",
    "llama",
    "gguf",
    "worker",
    "c0mpute"
  ],
  "dependencies": {
    "commander": "^12.1.0",
    "node-llama-cpp": "^3.5.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
